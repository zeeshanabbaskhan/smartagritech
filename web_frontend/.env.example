# EMS Web Dashboard — copy to .env.local for local dev
#
# Local dev (Vite proxy when using relative /api):
# VITE_API_URL=/api
# VITE_SOCKET_URL=http://localhost:5000
#
# CapRover production — baked into Docker image at build time (see web_frontend/Dockerfile).
# GitHub Actions sets this via CAPROVER_API_HOST when packing the frontend tarball.
VITE_API_URL=https://ems-api.yourdomain.com/api
VITE_SOCKET_URL=https://ems-api.yourdomain.com
