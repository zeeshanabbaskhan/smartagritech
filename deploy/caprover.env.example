# ═══════════════════════════════════════════════════════════════════════════════
# CapRover deployment — Smart AgriTech EMS
# ═══════════════════════════════════════════════════════════════════════════════
#
# Apps (create in CapRover GUI):
#   ems-postgres   — One-Click PostgreSQL
#   ems-redis      — One-Click Redis
#   ems-api        — Backend (tarball / GitHub Actions)
#   ems            — Frontend (tarball / GitHub Actions)
#
# ─── 1. Install CapRover on server ───
#   Use caprover/caprover:1.14.1+ if Docker 29+ (API 1.44+ required)
#   docker run -p 80:80 -p 443:443 -p 3000:3000 \
#     -e ACCEPTED_TERMS=true \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     -v caprover-data:/captain \
#     --name caprover --restart unless-stopped -d caprover/caprover:1.14.1
#
#   Dashboard: http://SERVER_IP:3000
#   Set root domain + enable HTTPS in Settings
#
# ─── 2. One-click databases ───
#   ems-postgres → save POSTGRES_PASSWORD
#   ems-redis    → deploy (no extra config)
#
# ─── 3. Backend app (ems-api) — App Configs → Environment Variables ───
NODE_ENV=production
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=30
INGEST_API_KEY=CHANGE_ME_ingest_key
CLIENT_URL=https://ems.CHANGE_ME.com
DATABASE_URL=postgresql://postgres:YOUR_PG_PASSWORD@srv-captain--ems-postgres:5432/postgres
REDIS_URL=redis://srv-captain--ems-redis:6379
INGEST_WORKER_CONCURRENCY=4
INGEST_BATCH_MAX=50
INGEST_BATCH_MS=100
SKIP_PG_CURRENT_VALUE=true
VALUE_FLUSH_MS=60000

# HTTP Settings: enable HTTPS, Force HTTPS, WebSocket Support
# Container port: 5000
# Health check path: /health

# ─── 4. Frontend app (ems) ───
# Container port: 80
# No runtime env vars. API URL is baked into the Docker image at build time using
# CAPROVER_BACKEND_PUBLIC_HOST (GitHub secret), e.g. ems-api.yourdomain.com
# Or manual pack: ./scripts/caprover/pack-frontend.sh ems-api.yourdomain.com

# ─── 5. DNS (HTTP Settings per app) ───
#   ems-api → ems-api.yourdomain.com
#   ems     → ems.yourdomain.com
#
# ─── 6. First deploy ───
#   GUI: Deployment → upload dist/caprover-backend.tgz / caprover-frontend.tgz
#   Or push to main → GitHub Actions auto-deploys per changed folder
#
# ─── 7. Seed users (once) ───
#   CapRover → ems-api → App Configs → terminal / one-off:
#   npm run seed
#
# ─── GitHub Actions secrets ───
#
# Create each app token in CapRover:
#   App → Deployment tab → Enable App Token → copy token
#
# Shared (both workflows):
#   CAPROVER_SERVER_URL           https://captain.yourdomain.com
#
# Backend workflow (caprover-deploy-backend.yml):
#   CAPROVER_BACKEND_APP          ems-api          (exact CapRover app name)
#   CAPROVER_BACKEND_TOKEN        <token from ems-api Deployment tab>
#
# Frontend workflow (caprover-deploy-frontend.yml):
#   CAPROVER_FRONTEND_APP         ems              (exact CapRover app name)
#   CAPROVER_FRONTEND_TOKEN       <token from ems Deployment tab>
#   CAPROVER_BACKEND_PUBLIC_HOST  ems-api.yourdomain.com
#                                 (public API hostname — NOT the captain URL;
#                                  used only to bake VITE_API_URL into the frontend build)
#
# Do NOT use the CapRover admin password in CI. Use per-app deploy tokens instead.
#
# ─── Manual pack (Windows) ───
#   .\scripts\caprover\pack-all.ps1 -ApiHost "ems-api.yourdomain.com" -WebHost "ems.yourdomain.com"
#
# ─── Manual pack (Linux / Mac) ───
#   ./scripts/caprover/pack-backend.sh
#   ./scripts/caprover/pack-frontend.sh ems-api.yourdomain.com
