# ═══════════════════════════════════════════════════════════════════════════════
# CapRover deployment — Smart AgriTech EMS
# ═══════════════════════════════════════════════════════════════════════════════
#
# Apps on this server (example names):
#   iotpostgres   — One-Click PostgreSQL
#   iotredis      — One-Click Redis
#   iotbackend    — Backend API (tarball / GitHub Actions)
#   iotfrontend   — Frontend dashboard (tarball / GitHub Actions)
#
# ─── 1. Install CapRover on server ───
#   Use caprover/caprover:1.14.1+ if Docker 29+ (API 1.44+ required)
#   docker run -p 80:80 -p 443:443 -p 3000:3000 \
#     -e ACCEPTED_TERMS=true \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     -v caprover-data:/captain \
#     --name caprover --restart unless-stopped -d caprover/caprover:1.14.1
#
#   Dashboard: http://SERVER_IP:3000
#   Set root domain + enable HTTPS in Settings
#
# ─── 2. One-click databases (CapRover internal hostnames) ───

# ─── 3. Backend app (iotbackend) — App Configs → Environment Variables ───
NODE_ENV=production
PORT=9001

JWT_SECRET=CHANGE_ME_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=30
INGEST_API_KEY=CHANGE_ME_ingest_key
CLIENT_URL=https://iotfrontend.yourdomain.com

# Complete connection URLs (CapRover internal network)
DATABASE_URL=
REDIS_URL=

INGEST_WORKER_CONCURRENCY=4
INGEST_BATCH_MAX=50
INGEST_BATCH_MS=100
SKIP_PG_CURRENT_VALUE=true
VALUE_FLUSH_MS=60000
DB_POOL_MAX=20
DB_POOL_IDLE_MS=30000
DB_POOL_TIMEOUT_MS=10000

# Optional — file uploads & email
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# NODEMAILER_USER=
# NODEMAILER_PASS=

# HTTP Settings: enable HTTPS, Force HTTPS, WebSocket Support
# Container port: 9001  (must match Dockerfile EXPOSE / PORT)
# Health check path: /health

# ─── 4. Frontend app (iotfrontend) ───
# Container port: 80
# No runtime env vars. API URL is baked into the Docker image at build time using
# CAPROVER_BACKEND_PUBLIC_HOST (GitHub secret), e.g. iotbackend.yourdomain.com
# Or manual pack: ./scripts/caprover/pack-frontend.sh iotbackend.yourdomain.com
#
# Resulting build-time values in the frontend image:
#   VITE_API_URL=https://iotbackend.yourdomain.com/api
#   VITE_SOCKET_URL=https://iotbackend.yourdomain.com

# ─── 5. DNS (HTTP Settings per app) ───
#   iotbackend  → iotbackend.yourdomain.com
#   iotfrontend → iotfrontend.yourdomain.com
#
# ─── 6. First deploy ───
#   GUI: Deployment → upload dist/caprover-backend.tgz / caprover-frontend.tgz
#   Or push to main → GitHub Actions auto-deploys per changed folder
#
# ─── 7. Seed users (automatic) ───
#   Runs automatically after the server starts on first deploy.
#   Skips if seed device "Energy Meter 01" already exists (no duplicate data).
#   Default users: superadmin@ems.com / orgadmin@ems.com / user@ems.com (password Admin@123456 or User@123456)
#   Disable with: SEED_ON_START=false
#   Manual re-run: npm run seed  (also skips if already seeded)
#
# ─── GitHub Actions secrets ───
#
# Create each app token in CapRover:
#   App → Deployment tab → Enable App Token → copy token
#
# Shared (both workflows):
#   CAPROVER_SERVER_URL           https://captain.yourdomain.com
#
# Backend workflow (caprover-deploy-backend.yml):
#   CAPROVER_BACKEND_APP          iotbackend       (exact CapRover app name)
#   CAPROVER_BACKEND_TOKEN        <token from iotbackend Deployment tab>
#
# Frontend workflow (caprover-deploy-frontend.yml):
#   CAPROVER_FRONTEND_APP         iotfrontend      (exact CapRover app name)
#   CAPROVER_FRONTEND_TOKEN       <token from iotfrontend Deployment tab>
#   CAPROVER_BACKEND_PUBLIC_HOST  iotbackend.yourdomain.com
#                                 (hostname ONLY — no https://, no /api)
#
# Do NOT use the CapRover admin password in CI. Use per-app deploy tokens instead.
#
# ─── Manual pack (Windows) ───
#   .\scripts\caprover\pack-all.ps1 -ApiHost "iotbackend.yourdomain.com" -WebHost "iotfrontend.yourdomain.com"
#
# ─── Manual pack (Linux / Mac) ───
#   ./scripts/caprover/pack-backend.sh
#   ./scripts/caprover/pack-frontend.sh iotbackend.yourdomain.com
