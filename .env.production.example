# ─── Copy to .env in project root before: docker compose up -d --build ───
# Generate secrets: openssl rand -hex 32

# Public URL of the web app (used for CORS + email links). No trailing slash.
# Use your VPS IP or domain, e.g. http://203.0.113.10 or https://ems.example.com
CLIENT_URL=http://YOUR_VPS_IP_OR_DOMAIN

# HTTP port exposed on the VPS (nginx serves UI + proxies /api and /socket.io)
HTTP_PORT=80

# ─── PostgreSQL (docker-compose postgres service) ───
POSTGRES_USER=ems
POSTGRES_PASSWORD=change_me_strong_postgres_password
POSTGRES_DB=ems

# ─── Auth ───
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=30

# ─── Device ingest (gateways / MQTT bridge) ───
# Global fallback key; per-device keys are also issued when creating devices
INGEST_API_KEY=change_me_ingest_api_key

# ─── Ingest performance (Redis is wired automatically in Docker) ───
INGEST_WORKER_CONCURRENCY=4
INGEST_BATCH_MAX=50
INGEST_BATCH_MS=100
INGEST_DEVICE_MAX_PER_MIN=180
SKIP_PG_CURRENT_VALUE=true
VALUE_FLUSH_MS=60000
REF_CACHE_TTL_SEC=300

# ─── Optional: email (leave blank to disable outbound mail) ───
# NODEMAILER_USER=
# NODEMAILER_PASS=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=alerts@yourdomain.com

# ─── Optional: Cloudinary (device images) ───
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Optional: Prisma query logging (debug only) ───
# PRISMA_LOG_QUERIES=false

# ─── Optional MQTT bridge (docker compose --profile mqtt up -d) ───
# MQTT_BROKER_IP=10.3.20.218
# MQTT_BROKER_PORT=1883
# MQTT_TOPIC=SMM/Soil_Data
# EMS_DEVICE_ID=<uuid-from-ems-after-creating-device>
# EMS_INGEST_API_KEY=<per-device-or-global-ingest-key>
# EMS_SLAVE_ID=
