PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ems
# Optional read replica for dashboard/analytics (P-32)
# DATABASE_READ_URL=postgresql://USER:PASSWORD@localhost:5432/ems
# PgBouncer transaction pool (P-30) — point DATABASE_URL at port 6432
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=30
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLIENT_URL=http://localhost:3000
NODEMAILER_USER=your_email@gmail.com
NODEMAILER_PASS=your_app_password
# SES / custom SMTP (P-55) — overrides Gmail when set
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=alerts@smartagritech.com
INGEST_API_KEY=your_global_ingest_fallback_key

# Device simulator (npm run simulate:devices)
# SIMULATOR_BASE_URL=http://localhost:5000
# SIMULATOR_INTERVAL_SEC=1
# SIMULATOR_CONCURRENCY=50

# Production fleet seed (npm run seed:fleet) — 100 devices / 10 gateways
# FLEET_DEVICE_COUNT=100
# FLEET_GATEWAY_COUNT=10

# Pool tuning (P-31)
DB_POOL_MAX=20
DB_POOL_IDLE_MS=30000
DB_POOL_TIMEOUT_MS=10000

# Redis — required for production-style batch ingest (BullMQ queue)
REDIS_URL=redis://localhost:6379
INGEST_WORKER_CONCURRENCY=4
INGEST_BATCH_MAX=50
INGEST_BATCH_MS=100
INGEST_DEVICE_MAX_PER_MIN=180

# Skip Postgres currentValue on hot path when Redis is up (P-09)
SKIP_PG_CURRENT_VALUE=true
VALUE_FLUSH_MS=60000
REF_CACHE_TTL_SEC=300
